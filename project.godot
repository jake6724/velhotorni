; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="tower_defense_jam"
run/main_scene="uid://421d4m7r6dw3"
config/features=PackedStringArray("4.4", "GL Compatibility")
run/max_fps=60
boot_splash/bg_color=Color(0.0941176, 0.0941176, 0.25098, 1)
boot_splash/fullsize=false
boot_splash/use_filter=false
boot_splash/image="uid://c5n4cc0k6ij2x"
config/icon="uid://df0lpdhv8ra1k"
boot_splash/minimum_display_time=3000

[autoload]

EnemySpawner="*res://scripts/singletons/enemy_spawner.gd"
WorldGrid="*res://scripts/singletons/world_grid.gd"
SFXPlayer="*res://scripts/singletons/sfx_player.gd"
MusicPlayer="*res://scripts/singletons/music_player.gd"
Constants="*res://scripts/singletons/constants.gd"
WaveManager="*res://scripts/singletons/wave_manager.gd"
SceneTransition="*res://scenes/ui/SceneTransition.tscn"
LevelManager="*res://scripts/singletons/level_manager.gd"
TowerGlobalData="*res://scripts/singletons/tower_global_data.gd"
TimeManager="*res://scripts/singletons/time_manager.gd"
Telemetry="*res://scripts/singletons/telemetry.gd"
StarRegistry="*res://scripts/singletons/star_registry.gd"

[debug]

gdscript/warnings/shadowed_global_identifier=0
gdscript/warnings/integer_division=0
gdscript/warnings/narrowing_conversion=0

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="canvas_items"
window/stretch/scale=1.2
mouse_cursor/custom_image="uid://d0ggh0ipjxkie"

[editor_plugins]

enabled=PackedStringArray("res://addons/tabby_explorer/plugin.cfg")

